# ~/.zshrc

## Sommaire
## ==1. Environnement & PATH
## ==2. Options zsh
## ==3. Historique
## ==4. Complétion
## ==5. Keybindings
## ==6. Prompt
## ==7. Aliases
## ==8. Fonctions
## ==9. Plugins / sources externes

## ==1. Environnement & PATH

export EDITOR=nvim
export VISUAL=nvim
export BROWSER=brave-origin
export LANG=fr_FR.UTF-8
export LC_ALL=fr_FR.UTF-8

path+=(
  "$HOME/.local/bin"
)
export PATH

## ==2. Options zsh

setopt AUTO_CD              # taper un chemin suffit pour y aller
setopt AUTO_PUSHD           # cd empile dans la pile de dirs
setopt PUSHD_IGNORE_DUPS    # pas de doublons dans la pile
setopt CORRECT              # correction de commandes
setopt NO_BEEP              # silence
setopt EXTENDED_GLOB        # globs avancés
setopt GLOB_DOTS            # les globs matchent les fichiers cachés
setopt INTERACTIVE_COMMENTS # autoriser # dans le shell interactif
setopt PROMPT_SUBST         # évaluer $() dans le prompt à chaque affichage

## ==3. Historique

HISTFILE="$HOME/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000

setopt SHARE_HISTORY        # partage entre sessions
setopt HIST_IGNORE_DUPS     # pas de lignes dupliquées consécutives
setopt HIST_IGNORE_SPACE    # ignorer les lignes précédées d'un espace
setopt HIST_VERIFY          # confirmer avant d'exécuter une expansion !
setopt HIST_REDUCE_BLANKS   # supprimer les espaces superflus

## ==4. Complétion

autoload -Uz compinit && compinit

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*:descriptions' format '%F{#89b4fa}── %d%f'
zstyle ':completion:*' group-name ''

## ==5. Keybindings

bindkey -v                           # mode vi

### Délai réduit pour la détection de la touche Escape
KEYTIMEOUT=1

### Bindings Ctrl conservés malgré le mode vi (kanata : lalt=lCtrl)
bindkey '^R' history-incremental-search-backward
bindkey '^A' beginning-of-line
bindkey '^E' end-of-line
bindkey '^K' kill-line
bindkey '^U' backward-kill-line
bindkey '^W' backward-kill-word
bindkey '^P' up-line-or-history
bindkey '^N' down-line-or-history

## ==6. Prompt

### Indicateur de mode vi dans le prompt (insert / normal)
function _vi_mode_indicator {
  case "$KEYMAP" in
    vicmd) echo '%F{#f9e2af}[N]%f ';;
    *)     echo '';;
  esac
}

function zle-line-init zle-keymap-select {
  zle reset-prompt
}
zle -N zle-line-init
zle -N zle-keymap-select

### Prompt : chemin · flèche (couleur selon code retour)
PROMPT='%F{#89b4fa}%~%f $(_vi_mode_indicator)%(?,%F{#a6e3a1},%F{#f38ba8})❯%f '

