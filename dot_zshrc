## ==8. Fonctions

### Yazi avec suivi du repertoire
function e() {
  local tmp=$(mktemp)
  yazi --cwd-file="$tmp" "$@"
  local cwd=$(cat "$tmp")
  [ -n "$cwd" ] && [ "$cwd" != "$PWD" ] && cd "$cwd"
  rm -f "$tmp"
}

### Créer un dossier et y entrer
function mkcd {
  mkdir -p "$1" && cd "$1"
}

### Afficher les processus consommateurs (top 10 cpu)
function topcpu {
  ps aux --sort=-%cpu | head -11
}

## ==9. Plugins / sources externes

### fzf : raccourcis clavier (Ctrl+T, Ctrl+R, Alt+C)
[[ -f /usr/share/fzf/key-bindings.zsh ]] && source /usr/share/fzf/key-bindings.zsh
[[ -f /usr/share/fzf/completion.zsh   ]] && source /usr/share/fzf/completion.zsh

### which fzf
alias-widget() {
     local selected
     selected=$(
       alias | sort | fzf \
         --height 50% \
         --reverse \
         --border rounded \
         --prompt ' alias> ' \
         --preview 'echo {} | sed "s/.*=//"' \
         --preview-window 'down:2:wrap'
     )
     [[ -z $selected ]] && { zle redisplay; return; }
     LBUFFER+="${selected%%=*}"
     zle redisplay
   }

   zle -N alias-widget
   bindkey '^ ' alias-widget   # Ctrl+Space

### scripts fzf : Ctrl+X → parcourir /data/scripts/python avec aperçu
scripts-widget() {
  local file base
  base=/data/scripts/python
  file=$(
    find "$base" -type f | sed "s|$base/||" | sort | fzf \
      --height 50% \
      --reverse \
      --border rounded \
      --prompt ' python > ' \
      --preview "bat --color=always --style=plain --paging=never $base/{}" \
      --preview-window 'right:60%:wrap'
  )
  [[ -z $file ]] && { zle redisplay; return; }
  LBUFFER+="python $base/$file"
  zle redisplay
}

zle -N scripts-widget
bindkey '^X' scripts-widget   # Ctrl+X
